# Copy this file to .env.local and fill in your values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Admin credentials
ADMIN_NAME=admin@example.com
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$...

# Vercel KV (from Vercel dashboard → Storage → KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob (from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=
